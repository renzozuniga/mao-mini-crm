# ── Database ─────────────────────────────────────────────────────────────────
# Supabase Session Pooler URL (recommended for Render free tier — uses IPv4)
# Get it from: Project Settings → Database → Connection string → Session pooler
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong key:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=changeme_use_a_strong_secret_in_production
JWT_ACCESS_EXPIRY=30m
JWT_REFRESH_EXPIRY=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4200
